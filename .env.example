# ==========================================
# IntelliDoc AI - Environment Variables
# ==========================================
# Copy this file to .env and replace the placeholder values.

# ------------------------------------------
# Environment & Application Settings
# ------------------------------------------
NODE_ENV=development
# The frontend URL (used for CORS and email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000
ALLOWED_ORIGIN=http://localhost:3000

# The backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ------------------------------------------
# Database (PostgreSQL / Prisma)
# ------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/intellidoc?schema=public

# ------------------------------------------
# Authentication (NextAuth & JWT)
# ------------------------------------------
# Generate a secret using: openssl rand -base64 32
AUTH_SECRET=your_super_secret_jwt_key_here
AUTH_TRUST_HOST=true

# GitHub OAuth
GITHUB_ID=your_github_oauth_client_id
GITHUB_SECRET=your_github_oauth_client_secret

# Google OAuth
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# ------------------------------------------
# Redis & BullMQ (Caching, Session, Queue)
# ------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ------------------------------------------
# Message Broker (RabbitMQ)
# ------------------------------------------
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# ------------------------------------------
# File Storage (AWS S3 / MinIO)
# ------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_BUCKET=intellidoc-documents
S3_BUCKET_NAME=intellidoc-documents
S3_ENDPOINT=http://localhost:9000
S3_FORCE_PATH_STYLE=true

# ------------------------------------------
# AI & Vector Embeddings
# ------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key
# Only required if using a custom local AI microservice
AI_SERVICE_URL=http://localhost:8000

# ------------------------------------------
# Vector Database (Qdrant)
# ------------------------------------------
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your_qdrant_api_key (optional for local)

# ------------------------------------------
# Email (SMTP for Password Reset / Invites)
# ------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
EMAIL_FROM="IntelliDoc AI" <noreply@intellidoc.ai>

# ------------------------------------------
# Payments (Razorpay)
# ------------------------------------------
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=your_razorpay_key_id

# ==========================================
# PRODUCTION (Vercel) Overrides
# ==========================================
# When deploying to Vercel, set these in the Vercel Dashboard:
#
# NODE_ENV=production
# NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
# APP_URL=https://your-domain.vercel.app
# ALLOWED_ORIGIN=https://your-domain.vercel.app
# AUTH_URL=https://your-domain.vercel.app
# AUTH_TRUST_HOST=true
# NEXT_PUBLIC_API_URL=https://intellidoc-ai-service.onrender.com/api/v1
# AI_SERVICE_URL=https://intellidoc-ai-service.onrender.com
#
# Also update on Render (AI Service):
#   ALLOWED_ORIGIN=https://your-domain.vercel.app
#
# And in Google Cloud Console:
#   Authorized redirect URI: https://your-domain.vercel.app/api/auth/callback/google

